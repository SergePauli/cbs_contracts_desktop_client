<Application
    x:Class="CbsContractsDesktopClient.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:helpers="using:CbsContractsDesktopClient.Helpers">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
                <ResourceDictionary Source="src/Styles/Theme/ShellColors.xaml" />
                <ResourceDictionary Source="src/Styles/Theme/ShellLayout.xaml" />
                <ResourceDictionary Source="src/Styles/Theme/Typography.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <helpers:BoolNegationConverter x:Key="BoolNegationConverter" />
            <helpers:BoolVisibilityConverter x:Key="BoolVisibilityConverter" />
            <helpers:StringVisibilityConverter x:Key="StringVisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
