<Page
    x:Class="CbsContractsDesktopClient.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CbsContractsDesktopClient.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFFFFF">
            <Grid Padding="28,36,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel HorizontalAlignment="Center">
                    <Border Width="58"
                            Height="58"
                            BorderBrush="#2C85CC"
                            BorderThickness="2"
                            CornerRadius="8"
                            Background="#EFF7FF">
                        <FontIcon Glyph="&#xE72E;"
                                  Foreground="#2C85CC"
                                  FontSize="28"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            Spacing="14">
                    <TextBlock Text="Авторизация"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#24364A" />

                    <TextBlock Text="Введите имя пользователя и пароль, чтобы войти в систему."
                               TextWrapping="Wrap"
                               Foreground="#6B7C90" />

                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <HyperlinkButton Content="Регистрация"
                                         Click="RegistrationLink_Click"
                                         Padding="0" />
                        <TextBlock Text="•"
                                   VerticalAlignment="Center"
                                   Foreground="#9AA8B6" />
                        <HyperlinkButton Content="Не помню пароль"
                                         Click="ForgotPasswordLink_Click"
                                         Padding="0" />
                    </StackPanel>

                    <TextBox Header="Логин"
                             Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Введите логин"
                             IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />

                    <PasswordBox x:Name="PasswordInput"
                                 Header="Пароль"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 PlaceholderText="Введите пароль"
                                 IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />

                    <CheckBox Content="Запомнить меня"
                              IsChecked="{x:Bind ViewModel.RememberMe, Mode=TwoWay}"
                              IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />

                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                               Foreground="#B42318"
                               Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringVisibilityConverter}}"
                               TextWrapping="Wrap" />

                    <Button Content="Войти"
                            Command="{x:Bind ViewModel.LoginCommand}"
                            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                            HorizontalAlignment="Stretch"
                            Margin="0,6,0,0" />

                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  HorizontalAlignment="Center"
                                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolVisibilityConverter}}"
                                  Margin="0,6,0,0" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="2012-2026 © ООО &quot;ЦБС&quot;"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Foreground="#A3AFBB"
                           FontSize="12"
                           Opacity="0.85" />
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5FAFF" Offset="0" />
                    <GradientStop Color="#E4F0FB" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>

            <Grid Padding="56,54,56,34">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="10"
                            MaxWidth="540"
                            HorizontalAlignment="Center">
                    <Border Width="140"
                            Height="140"
                            HorizontalAlignment="Center"
                            Background="#10FFFFFF"
                            CornerRadius="16"
                            Padding="6"
                            Margin="0,0,0,14">
                        <Image Source="ms-appx:///Assets/login-logo-clean.png"
                               Width="120"
                               Height="120"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="База контрактов и контрагентов"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#1B3550"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,18,0,0"
                               Text="Единый настольный клиент для работы с базой контрактов и контрагентов в среде Windows."
                               FontSize="16"
                               Foreground="#5A7A98"
                               TextWrapping="Wrap"
                               MaxWidth="520" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="версия 1.0.0"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,0"
                           Foreground="#87A0B8"
                           FontSize="14"
                           FontWeight="Normal"
                           Opacity="0.85" />
            </Grid>
        </Grid>
    </Grid>
</Page>
