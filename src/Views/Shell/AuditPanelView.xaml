<UserControl
    x:Class="CbsContractsDesktopClient.Views.Shell.AuditPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Background="{StaticResource ShellPanelBackgroundBrush}"
        BorderBrush="{StaticResource ShellPanelBorderBrush}"
        BorderThickness="1"
        CornerRadius="{StaticResource ShellPanelCornerRadius}"
        Padding="{StaticResource ShellAuditPadding}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Foreground="{StaticResource ShellPrimaryTextBrush}"
                    Text="{x:Bind ViewModel.AuditPanelState.Title, Mode=OneWay}" />
                <TextBlock
                    Style="{StaticResource BodyTextBlockStyle}"
                    FontSize="13"
                    Foreground="{StaticResource ShellSecondaryTextBrush}"
                    Text="{x:Bind ViewModel.AuditPanelState.Description, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer
                x:Name="AuditScrollViewer"
                Grid.Row="1"
                Margin="0,18,0,0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                ViewChanged="AuditScrollViewer_ViewChanged">
                <Grid>
                    <Border
                        Width="2"
                        Margin="10,0,0,0"
                        HorizontalAlignment="Left"
                        Background="{StaticResource ShellAccentMutedBrush}"
                        Opacity="0.55" />
                    <StackPanel x:Name="AuditTimelineHost" />
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
