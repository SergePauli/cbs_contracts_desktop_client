<UserControl
    x:Class="CbsContractsDesktopClient.Views.Shell.AuditPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Background="{StaticResource ShellPanelBackgroundBrush}"
        BorderBrush="{StaticResource ShellPanelBorderBrush}"
        BorderThickness="1"
        CornerRadius="{StaticResource ShellPanelCornerRadius}"
        Padding="{StaticResource ShellAuditPadding}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Foreground="{StaticResource ShellPrimaryTextBrush}"
                    Text="Аудит" />
                <TextBlock
                    Style="{StaticResource BodyTextBlockStyle}"
                    FontSize="13"
                    Foreground="{StaticResource ShellSecondaryTextBrush}"
                    Text="Компактная правая панель. Позже станет скрывающейся." />
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                Margin="0,18,0,0"
                Spacing="10">
                <Border
                    Padding="12"
                    Background="{StaticResource ShellAccentPanelBackgroundBrush}"
                    CornerRadius="{StaticResource ShellAuditItemCornerRadius}">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            FontSize="13"
                            Foreground="{StaticResource ShellPrimaryTextBrush}"
                            Text="12:40 Обновлено" />
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{StaticResource ShellSecondaryTextBrush}"
                            Text="Изменены основные поля карточки." />
                    </StackPanel>
                </Border>

                <Border
                    Padding="12"
                    Background="{StaticResource ShellAccentPanelBackgroundAltBrush}"
                    CornerRadius="{StaticResource ShellAuditItemCornerRadius}">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            FontSize="13"
                            Foreground="{StaticResource ShellPrimaryTextBrush}"
                            Text="11:55 Создано" />
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{StaticResource ShellSecondaryTextBrush}"
                            Text="Здесь позже будет таймлайн изменений." />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
