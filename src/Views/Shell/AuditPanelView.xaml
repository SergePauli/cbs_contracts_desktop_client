<UserControl
    x:Class="CbsContractsDesktopClient.Views.Shell.AuditPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Background="#FCFFFFFF"
        BorderBrush="#0F000000"
        BorderThickness="1"
        CornerRadius="18"
        Padding="18,18,18,18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="#FF242424"
                    Text="Аудит" />
                <TextBlock
                    FontSize="13"
                    Foreground="#FF707070"
                    Text="Компактная правая панель. Позже станет скрывающейся." />
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                Margin="0,18,0,0"
                Spacing="10">
                <Border
                    Padding="12"
                    Background="#FFF6F6F6"
                    CornerRadius="14">
                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#FF242424"
                            Text="12:40 Обновлено" />
                        <TextBlock
                            FontSize="12"
                            Foreground="#FF666666"
                            Text="Изменены основные поля карточки." />
                    </StackPanel>
                </Border>

                <Border
                    Padding="12"
                    Background="#FFF6F6F6"
                    CornerRadius="14">
                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#FF242424"
                            Text="11:55 Создано" />
                        <TextBlock
                            FontSize="12"
                            Foreground="#FF666666"
                            Text="Здесь позже будет таймлайн изменений." />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
