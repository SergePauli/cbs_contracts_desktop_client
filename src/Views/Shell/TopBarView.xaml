<UserControl
    x:Class="CbsContractsDesktopClient.Views.Shell.TopBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        BorderBrush="{StaticResource ShellPanelBorderBrush}"
        BorderThickness="0,0,0,1">
        <Grid Padding="{StaticResource ShellTopBarPadding}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Button
            Width="{StaticResource ShellBackButtonSize}"
            Height="{StaticResource ShellBackButtonSize}"
            Padding="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderBrush="{x:Null}"
            Content="&#xE76B;"
            FontFamily="Segoe Fluent Icons"
            FontSize="14"
            Foreground="{StaticResource ShellSecondaryTextBrush}" />

        <Button
            Grid.Column="1"
            Width="{StaticResource ShellBackButtonSize}"
            Height="{StaticResource ShellBackButtonSize}"
            Padding="0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderBrush="{x:Null}"
            Content="&#xE76C;"
            FontFamily="Segoe Fluent Icons"
            FontSize="14"
            Foreground="{StaticResource ShellAccentMutedBrush}" />

        <Border
            Grid.Column="3"
            Height="{StaticResource ShellSearchHeight}"
            VerticalAlignment="Center"
            Background="{StaticResource ShellPanelBackgroundBrush}"
            BorderBrush="{StaticResource ShellPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource ShellSearchCornerRadius}">
            <Grid Padding="{StaticResource ShellTopBarSearchPadding}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="14"
                    Foreground="{StaticResource ShellSecondaryTextBrush}"
                    Text="&#xE721;" />
                <TextBlock
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    Style="{StaticResource BodyTextBlockStyle}"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource ShellSecondaryTextBrush}"
                    Text="Поиск" />
            </Grid>
        </Border>
        </Grid>
    </Border>
</UserControl>
