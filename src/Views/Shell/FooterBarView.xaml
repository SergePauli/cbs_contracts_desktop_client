<UserControl
    x:Class="CbsContractsDesktopClient.Views.Shell.FooterBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        BorderBrush="{StaticResource ShellPanelBorderBrush}"
        BorderThickness="0,1,0,0">
        <Grid Padding="{StaticResource ShellFooterPadding}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Orientation="Horizontal"
                Spacing="0"
                VerticalAlignment="Center">
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource ShellTertiaryTextBrush}"
                    Text="Записей:" />
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource ShellPrimaryTextBrush}"
                    Text="{x:Bind ViewModel.FooterState.TotalCountValue, Mode=OneWay}" />
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource ShellTertiaryTextBrush}"
                    Margin="6,0,6,0"
                    Text="{x:Bind ViewModel.FooterState.SelectedRecordSeparator, Mode=OneWay}" />
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource ShellTertiaryTextBrush}"
                    Text="{x:Bind ViewModel.FooterState.SelectedRecordCaption, Mode=OneWay}" />
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource ShellTableRowSelectedBorderBrush}"
                    Text="{x:Bind ViewModel.FooterState.SelectedRecordText, Mode=OneWay}" />
            </StackPanel>
            <TextBlock
                Grid.Column="1"
                Style="{StaticResource CaptionTextBlockStyle}"
                VerticalAlignment="Center"
                Foreground="{StaticResource ShellCaptionTextBrush}"
                Text="{x:Bind ViewModel.FooterState.VersionText, Mode=OneWay}" />
        </Grid>
    </Border>
</UserControl>
