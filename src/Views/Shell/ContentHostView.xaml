<UserControl
    x:Class="CbsContractsDesktopClient.Views.Shell.ContentHostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="12,12,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                FontSize="26"
                FontWeight="SemiBold"
                Foreground="#FF242424"
                Text="Люди" />

            <Button
                Grid.Column="1"
                Width="36"
                Height="36"
                Padding="0"
                Background="Transparent"
                BorderBrush="{x:Null}"
                Content="⚙"
                FontSize="18"
                Foreground="#FF616161" />
        </Grid>

        <Border
            Grid.Row="1"
            Margin="0"
            Background="#FFFFFFFF"
            BorderBrush="#0F000000"
            BorderThickness="1"
            CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="72" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Background="#FFFFFFFF"
                    CornerRadius="18,18,0,0">
                    <TextBlock
                        Margin="24,0,24,0"
                        VerticalAlignment="Center"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="#FF242424"
                        Text="Все контакты" />
                </Border>

                <Grid
                    Grid.Row="1"
                    Background="#FFF9F9F9"
                    CornerRadius="0,0,18,18"
                    Padding="24,20,24,24">
                    <TextBlock
                        FontSize="14"
                        Foreground="#FF616161"
                        Text="Здесь позже будет host рабочих страниц. Поверхность остаётся лёгкой и почти без визуального шума." />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
