<UserControl
    x:Class="CbsContractsDesktopClient.Views.Shell.ContentHostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="{StaticResource ShellContentHeaderPadding}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Style="{StaticResource TitleTextBlockStyle}"
                VerticalAlignment="Center"
                FontSize="26"
                Foreground="{StaticResource ShellPrimaryTextBrush}"
                Text="Люди" />

            <Button
                Grid.Column="1"
                Width="{StaticResource ShellActionButtonSize}"
                Height="{StaticResource ShellActionButtonSize}"
                Padding="0"
                Background="Transparent"
                BorderBrush="{x:Null}"
                Content="&#xE713;"
                FontFamily="Segoe Fluent Icons"
                FontSize="14"
                Foreground="{StaticResource ShellSecondaryTextBrush}" />
        </Grid>

        <Border
            Grid.Row="1"
            Margin="0"
            Background="{StaticResource ShellPanelBackgroundBrush}"
            BorderBrush="{StaticResource ShellPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource ShellPanelCornerRadius}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{StaticResource ShellContentHeaderCardHeight}" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Background="{StaticResource ShellPanelBackgroundBrush}"
                    CornerRadius="{StaticResource ShellPanelTopCornerRadius}">
                    <TextBlock
                        Margin="24,0,24,0"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        VerticalAlignment="Center"
                        FontSize="22"
                        Foreground="{StaticResource ShellPrimaryTextBrush}"
                        Text="Все контакты" />
                </Border>

                <Grid
                    Grid.Row="1"
                    Background="{StaticResource ShellMutedPanelBackgroundBrush}"
                    CornerRadius="{StaticResource ShellPanelBottomCornerRadius}"
                    Padding="{StaticResource ShellContentBodyPadding}">
                    <TextBlock
                        Style="{StaticResource BodyTextBlockStyle}"
                        FontSize="14"
                        Foreground="{StaticResource ShellSecondaryTextBrush}"
                        Text="Здесь позже будет host рабочих страниц. Поверхность остаётся лёгкой и почти без визуального шума." />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
