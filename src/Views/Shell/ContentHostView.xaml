<UserControl
    x:Class="CbsContractsDesktopClient.Views.Shell.ContentHostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CbsContractsDesktopClient.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="{StaticResource ShellContentHeaderPadding}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Style="{StaticResource TitleTextBlockStyle}"
                VerticalAlignment="Center"
                FontSize="26"
                Foreground="{StaticResource ShellPrimaryTextBrush}"
                Text="{Binding SectionTitle}" />

            <Button
                Grid.Column="1"
                Width="{StaticResource ShellActionButtonSize}"
                Height="{StaticResource ShellActionButtonSize}"
                Padding="0"
                Background="Transparent"
                BorderBrush="{x:Null}"
                Content="&#xE713;"
                FontFamily="Segoe Fluent Icons"
                FontSize="14"
                Foreground="{StaticResource ShellSecondaryTextBrush}" />
        </Grid>

        <Border
            Grid.Row="1"
            Margin="0"
            Background="{StaticResource ShellPanelBackgroundBrush}"
            BorderBrush="{StaticResource ShellPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{StaticResource ShellContentHeaderCardHeight}" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Background="{StaticResource ShellPanelBackgroundBrush}"
                    CornerRadius="0">
                    <Grid Margin="16,0,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            VerticalAlignment="Center"
                            FontSize="22"
                            Foreground="{StaticResource ShellPrimaryTextBrush}"
                            Text="{Binding ContentTitle}" />

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource ShellSecondaryTextBrush}"
                            Text="{Binding ContentDescription}" />
                    </Grid>
                </Border>

                <Grid
                    Grid.Row="1"
                    Background="{StaticResource ShellMutedPanelBackgroundBrush}"
                    Padding="0">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid
                            Padding="8,6,8,6"
                            Background="{StaticResource ShellPanelBackgroundBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ProgressRing
                                    Width="16"
                                    Height="16"
                                    IsActive="{Binding IsLoading}" />

                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource ShellSecondaryTextBrush}"
                                    Text="{Binding TotalCountText}"
                                    Visibility="{Binding HasActiveReference, Converter={StaticResource BoolVisibilityConverter}}" />

                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource ShellSecondaryTextBrush}"
                                    Text="Выберите поддерживаемый справочник в меню, чтобы открыть таблицу."
                                    Visibility="{Binding ShowPlaceholder, Converter={StaticResource BoolVisibilityConverter}}" />
                            </StackPanel>

                            <Button
                                Grid.Column="1"
                                Width="{StaticResource ShellActionButtonSize}"
                                Height="{StaticResource ShellActionButtonSize}"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="{x:Null}"
                                Content="&#xE713;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{StaticResource ShellSecondaryTextBrush}" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <controls:CbsTableView
                                x:Name="ReferenceTableView"
                                Columns="{Binding CurrentColumns}"
                                CurrentSortDirection="{Binding CurrentSortDirection}"
                                CurrentSortField="{Binding CurrentSortField}"
                                TableStateKey="{Binding CurrentTableStateKey}"
                                Density="Compact"
                                HasMoreItems="{Binding HasMoreItems}"
                                IsLoading="{Binding IsLoading}"
                                ItemsSource="{Binding Items}"
                                LoadedCount="{Binding LoadedCount}"
                                LoadMoreRequested="ReferenceTableView_LoadMoreRequested"
                                Margin="0"
                                SupportsMultipleRowSelection="False"
                                SupportsRowSelection="True"
                                ColumnWidthChanged="ReferenceTableView_ColumnWidthChanged"
                                FilterRequested="ReferenceTableView_FilterRequested"
                                SortRequested="ReferenceTableView_SortRequested"
                                TotalCount="{Binding TotalCount}"
                                TraceGenerated="ReferenceTableView_TraceGenerated"
                                Visibility="{Binding HasActiveReference, Converter={StaticResource BoolVisibilityConverter}}" />

                            <Border
                                Padding="24"
                                Background="{StaticResource ShellPanelBackgroundBrush}"
                                BorderBrush="{StaticResource ShellPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Visibility="{Binding ShowPlaceholder, Converter={StaticResource BoolVisibilityConverter}}">
                                <StackPanel
                                    MaxWidth="620"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Spacing="10">
                                    <TextBlock
                                        Style="{StaticResource SubtitleTextBlockStyle}"
                                        Foreground="{StaticResource ShellPrimaryTextBrush}"
                                        Text="{Binding ContentTitle}" />
                                    <TextBlock
                                        Foreground="{StaticResource ShellSecondaryTextBrush}"
                                        Text="{Binding PlaceholderMessage}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>

                            <Border
                                Padding="16"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="{StaticResource ShellPanelBackgroundBrush}"
                                BorderBrush="{StaticResource ShellPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringVisibilityConverter}}">
                                <TextBlock
                                    MaxWidth="520"
                                    Foreground="IndianRed"
                                    Text="{Binding ErrorMessage}"
                                    TextWrapping="WrapWholeWords" />
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
