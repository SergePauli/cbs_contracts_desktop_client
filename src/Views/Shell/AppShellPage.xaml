<Page
    x:Class="CbsContractsDesktopClient.Views.Shell.AppShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="using:CbsContractsDesktopClient.Views.Shell"
    mc:Ignorable="d">

    <Grid Background="#FFF3F2F1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="182" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="384" />
        </Grid.ColumnDefinitions>

        <shell:NavigationSidebarView Grid.Column="0" />

        <Grid Grid.Column="1" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <shell:TopBarView Grid.Row="0" />
            <shell:ContentHostView Grid.Row="1" Margin="12,0,0,12" />
            <shell:FooterBarView Grid.Row="2" />
        </Grid>

        <shell:AuditPanelView Grid.Column="2" Margin="0,12,12,12" />
    </Grid>
</Page>
