<Page
    x:Class="CbsContractsDesktopClient.Views.Shell.AppShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="using:CbsContractsDesktopClient.Views.Shell"
    mc:Ignorable="d">

    <Grid Background="{StaticResource ShellWindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource ShellSidebarWidth}" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="{StaticResource ShellAuditWidth}" />
        </Grid.ColumnDefinitions>

        <shell:NavigationSidebarView x:Name="SidebarView" Grid.Column="0" />

        <Grid Grid.Column="1" Margin="{StaticResource ShellContentRegionMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="{StaticResource ShellTopBarHeight}" />
                <RowDefinition Height="*" />
                <RowDefinition Height="{StaticResource ShellFooterHeight}" />
            </Grid.RowDefinitions>

            <shell:TopBarView Grid.Row="0" />
            <shell:ContentHostView Grid.Row="1" Margin="{StaticResource ShellContentHostMargin}" />
            <shell:FooterBarView Grid.Row="2" />
        </Grid>

        <shell:AuditPanelView Grid.Column="2" Margin="{StaticResource ShellAuditMargin}" />
    </Grid>
</Page>
