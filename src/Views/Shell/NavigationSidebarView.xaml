<UserControl
    x:Class="CbsContractsDesktopClient.Views.Shell.NavigationSidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <NavigationView
        x:Name="SidebarNavigationView"
        PaneDisplayMode="Left"
        IsPaneOpen="True"
        IsPaneToggleButtonVisible="False"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        AlwaysShowHeader="False"
        CompactModeThresholdWidth="0"
        ExpandedModeThresholdWidth="0"
        PaneTitle=""
        ItemInvoked="SidebarNavigationView_ItemInvoked"
        SelectionChanged="SidebarNavigationView_SelectionChanged" />
</UserControl>
