<UserControl
    x:Class="CbsContractsDesktopClient.Views.Shell.NavigationSidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Background="#FFF7F7F7"
        BorderBrush="#11000000"
        BorderThickness="0,0,1,0">
        <Grid Padding="14,10,12,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="34"
                    Height="34"
                    VerticalAlignment="Center"
                    Background="#FFE8E6FF"
                    CornerRadius="10">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="#FF5B5FC7"
                        Text="Ц" />
                </Border>

                <TextBlock
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="#FF242424"
                    Text="Навигация" />
            </Grid>

            <StackPanel
                Grid.Row="1"
                Margin="0,18,0,0"
                Spacing="6">
                <Border
                    MinHeight="44"
                    Background="#FFF0EFEF"
                    CornerRadius="12">
                    <Grid Padding="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FF5B5FC7"
                            Text="≡" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#FF242424"
                            Text="Договоры" />
                    </Grid>
                </Border>

                <Border
                    MinHeight="44"
                    Background="Transparent"
                    CornerRadius="12">
                    <Grid Padding="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FF616161"
                            Text="⌂" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="#FF3A3A3A"
                            Text="Главная" />
                    </Grid>
                </Border>

                <Border
                    MinHeight="44"
                    Background="Transparent"
                    CornerRadius="12">
                    <Grid Padding="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#FF616161"
                            Text="◫" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="#FF3A3A3A"
                            Text="Справочники" />
                    </Grid>
                </Border>
            </StackPanel>

            <TextBlock
                Grid.Row="2"
                Margin="12,0,0,0"
                FontSize="12"
                Foreground="#FF707070"
                Text="Shell navigation" />
        </Grid>
    </Border>
</UserControl>
