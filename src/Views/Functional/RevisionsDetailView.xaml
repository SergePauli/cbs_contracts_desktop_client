<UserControl
    x:Class="CbsContractsDesktopClient.Views.Functional.RevisionsDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CbsContractsDesktopClient.Views.Functional"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:references="using:CbsContractsDesktopClient.Views.References"
    mc:Ignorable="d">

    <Border
        Height="360"
        Style="{StaticResource ShellDetailFooterRootBorderStyle}">
        <Grid
            Padding="4"
            ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72*" />
                <ColumnDefinition Width="28*" />
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Column="0"
                RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="ContractNameTextBlock"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Foreground="{StaticResource ShellPrimaryTextBrush}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        x:Name="ContragentNameTextBlock"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Foreground="{StaticResource ShellSecondaryTextBrush}"
                        FontStyle="Italic"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <Grid
                        x:Name="ContactsPanel"
                        VerticalAlignment="Center"
                        ColumnSpacing="0"
                        RowSpacing="0" />
                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    Spacing="8">
                    <TextBlock
                        x:Name="PerformersTextBlock"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{StaticResource ShellSecondaryTextBrush}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />

                    <Border
                        MinHeight="132"
                        Padding="4"
                        Background="{StaticResource ShellPanelBackgroundBrush}"
                        BorderBrush="{StaticResource ShellPanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Foreground="{StaticResource ShellTertiaryTextBrush}"
                                Text="Комментарии" />
                            <local:CommentBox
                                x:Name="CommentsBox"
                                Grid.Row="1" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Border
                Grid.Column="1"
                Style="{StaticResource ShellDetailFooterColumnSeparatorStyle}">
                <references:EmployeeBox
                    x:Name="EmployeesBox"
                    CanEdit="False" />
            </Border>
        </Grid>
    </Border>
</UserControl>
