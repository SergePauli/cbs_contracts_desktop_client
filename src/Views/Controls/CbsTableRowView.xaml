<UserControl
    x:Class="CbsContractsDesktopClient.Views.Controls.CbsTableRowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        x:Name="RowBorder"
        Background="{StaticResource ShellTableRowBackgroundBrush}"
        BorderBrush="{StaticResource ShellTableGridLineBrush}"
        BorderThickness="0,0,0,1">
        <Grid>
            <Border
                x:Name="SelectionAccent"
                Width="2"
                HorizontalAlignment="Left"
                Background="{StaticResource ShellTableRowSelectedBorderBrush}"
                Visibility="Collapsed" />
            <Grid x:Name="RowGrid" />
        </Grid>
    </Border>
</UserControl>
